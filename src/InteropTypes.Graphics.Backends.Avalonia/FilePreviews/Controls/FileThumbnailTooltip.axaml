<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:thumb="using:InteropTypes.IO.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InteropTypes.IO.Controls.FileThumbnailToolTip">
  
    <StackPanel DataContext="{Binding $parent[thumb:FileThumbnailBox]}" >

        <TextBlock TextWrapping="Wrap" Text="{Binding Source.Name}" HorizontalAlignment="Center" />

		<Image Source="{Binding Bitmap}" Stretch="Uniform" MaxWidth="800" MaxHeight="600" />

        <!-- we need to report the actual image size, not the size of the thumbnail!!!!!
        <TextBlock HorizontalAlignment="Center">
			<TextBlock.Text>
				<MultiBinding StringFormat="{}{0}x{1}">
                    <Binding Path="Bitmap.Size.Width" />
                    <Binding Path="Bitmap.Size.Height" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
        -->
        
    </StackPanel>

</UserControl>
