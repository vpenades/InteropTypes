<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:drawing="using:InteropTypes.Graphics.Drawing"
             xmlns:drwctrl="using:InteropTypes.Graphics.Backends.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InteropTypes.Graphics.Backends.Views.DrawingBrushCanvas2DView">

    <!-- https://github.com/AvaloniaUI/Avalonia/issues/391 -->
             

    <drwctrl:Canvas2DView Canvas="{Binding}" x:DataType="{x:Type drawing:IDrawingBrush, x:TypeArguments=drawing:ICanvas2D}" />
  
</UserControl>
