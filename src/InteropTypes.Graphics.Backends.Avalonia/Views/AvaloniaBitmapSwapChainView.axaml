<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avlbmp="using:InteropTypes.Graphics.Backends.Bitmaps"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InteropTypes.Graphics.Backends.Views.AvaloniaBitmapSwapChainView"
             x:DataType="avlbmp:AvaloniaBitmapSwapChain">
  
    <Image Source="{Binding FrontBuffer}" />

</UserControl>
