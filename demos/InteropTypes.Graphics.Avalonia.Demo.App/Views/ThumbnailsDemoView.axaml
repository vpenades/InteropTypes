<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sysio="using:System.IO"
			 xmlns:vm="clr-namespace:InteropTypes.ViewModels"
			 xmlns:l="clr-namespace:InteropTypes.Views"
			 xmlns:interop="urn:InteropTypes"
			 xmlns:bckavl="using:InteropTypes.Graphics.Backends.AVL"
			 xmlns:thumb="using:InteropTypes.IO.Controls"
			 xmlns:demo="using:InteropTypes"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InteropTypes.Views.ThumbnailsDemoView">
  
	<Grid RowDefinitions="auto *">						 

		<Button Content="Browse Directory..." Click="_OnClick_PickDirectory" />

		<!-- https://github.com/AvaloniaUI/Avalonia/issues/18798 -->
		<!-- https://github.com/AvaloniaUI/Avalonia/discussions/16829 -->
		<!-- https://github.com/AvaloniaUI/Avalonia.Controls.ItemsRepeater?tab=readme-ov-file#current-status -->
		<!-- https://github.com/AvaloniaUI/Avalonia.Controls.ItemsRepeater/issues/29 -->

		<ScrollViewer Grid.Row="1">

			<ItemsRepeater x:Name="myDirectoryFiles">

				<ItemsRepeater.Layout>
					<UniformGridLayout MinItemWidth="64" MinItemHeight="64" MinColumnSpacing="2" MinRowSpacing="2" />
				</ItemsRepeater.Layout>

				
				<ItemsRepeater.ItemTemplate>
					<DataTemplate x:DataType="sysio:FileSystemInfo">
						<thumb:FileThumbnailBox FileThumbnailFactory="{StaticResource myThumbnailsCache}" FileSystemSource="{Binding}" DoubleTapped="FileThumbnailBox_DoubleTapped" />
					</DataTemplate>
				</ItemsRepeater.ItemTemplate>
				

			</ItemsRepeater>
		</ScrollViewer>
						 
	</Grid>


</UserControl>
